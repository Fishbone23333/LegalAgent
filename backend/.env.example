# DeepSeek API配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# MiniMax API配置（使用OpenAI兼容格式）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.7

# API服务配置
APP_NAME=LegalShield Agent
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# 当前使用的模型提供商: deepseek / minimax
LLM_PROVIDER=deepseek

# 前端配置
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# RAG 法律知识库配置
# ─────────────────────────────────────────────

# 嵌入模型（Ollama，本地运行）
# 默认使用 nomic-embed-text（支持中文，推荐）
# 安装命令：ollama pull nomic-embed-text
LEGAL_EMBEDDING_MODEL=nomic-embed-text
LEGAL_EMBEDDING_BASE_URL=http://localhost:11434

# 索引持久化路径（可选，默认保存在 rag/data/legal_faiss）
# LEGAL_INDEX_PATH=

# 检索模式：semantic（纯向量）/ keyword（纯关键词）/ hybrid（混合，默认）
# LEGAL_SEARCH_MODE=hybrid
